# Phoenix v4 placeholders only. Do not commit .env.
PHOENIX_MODE=SHADOW
LIVE_EXECUTION=false
PHOENIX_ENV=production
CHAIN_ID=42161

NATS_URL=nats://nats:4222
RECORDER_BATCH_MAX_SIZE=256
RECORDER_BATCH_MAX_WAIT_MS=100
POSTGRES_USER=phoenix_app
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=phoenix
POSTGRES_DSN=postgres://phoenix_app:REPLACE_ME@postgres:5432/phoenix
METRICS_ADDR=0.0.0.0:9100
PHOENIX_FEED_SOURCE=relay
PHOENIX_FEED_RELAY_URL=ws://nitro-feed-relay:9642/feed
PHOENIX_FEED_FIXTURE=
ARBITRUM_SEQUENCER_FEED_URL=wss://arb1-feed.arbitrum.io/feed

# Cold RPC gateway provider URLs. Use low-quota providers here; hot path does not read RPC.
RPC_PROVIDER_URLS=https://replace-with-quicknode-endpoint.example,https://arbitrum.drpc.org,https://arbitrum-one-rpc.publicnode.com,https://arb1.arbitrum.io/rpc
RPC_PROVIDER_WEIGHTS=4,3,1,1
RPC_GLOBAL_RPS=5

# Empty keeps Engine readiness false. Replace only with a reviewed canonical route registry.
ENGINE_ROUTE_REGISTRY_JSON=[]

# Required only for integration/fork validation.
ARBITRUM_RPC_URL=https://arbitrum.drpc.org
PARENT_CHAIN_RPC_URL=https://eth.drpc.org

# Required only for LIVE after release gate.
EXECUTOR_ADDRESS=
SIGNER_PRIVATE_KEY=

# Sushi V3 values must be verified from official Sushi source before setting.
SUSHI_V3_FACTORY=
SUSHI_V3_ROUTER=
SUSHI_V3_QUOTER=
SUSHI_V3_INIT_CODE_HASH=
