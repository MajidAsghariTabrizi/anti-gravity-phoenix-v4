{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenix.invalid/schemas/phoenix-executor-deployment.schema.json",
  "title": "PhoenixExecutor Arbitrum One deployment manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "source_commit_sha",
    "chain_id",
    "deployer_address",
    "owner_address",
    "flash_provider_address",
    "contract_address",
    "deployment_transaction_hash",
    "bytecode_hash_algorithm",
    "creation_bytecode_hash",
    "runtime_bytecode_hash",
    "compiler"
  ],
  "properties": {
    "schema": {
      "const": "phoenix.executor-deployment.v1"
    },
    "source_commit_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "chain_id": {
      "const": 42161
    },
    "deployer_address": {
      "$ref": "#/$defs/address"
    },
    "owner_address": {
      "const": "0x9F30c00B68F7C0eDb4b4117B9f04E0cA2EB2C17a"
    },
    "flash_provider_address": {
      "const": "0x794a61358D6845594F94dc1DB02A252b5b4814aD"
    },
    "contract_address": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/address"
        }
      ]
    },
    "deployment_transaction_hash": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^0x[0-9a-f]{64}$"
        }
      ]
    },
    "bytecode_hash_algorithm": {
      "const": "keccak256"
    },
    "creation_bytecode_hash": {
      "$ref": "#/$defs/hash"
    },
    "runtime_bytecode_hash": {
      "$ref": "#/$defs/hash"
    },
    "compiler": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "optimizer_enabled",
        "optimizer_runs"
      ],
      "properties": {
        "version": {
          "const": "0.8.24"
        },
        "optimizer_enabled": {
          "const": true
        },
        "optimizer_runs": {
          "const": 200
        }
      }
    }
  },
  "$defs": {
    "address": {
      "type": "string",
      "pattern": "^0x[0-9a-fA-F]{40}$"
    },
    "hash": {
      "type": "string",
      "pattern": "^0x[0-9a-f]{64}$"
    }
  }
}
