{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenix.invalid/schemas/phoenix-release-provenance.schema.json",
  "title": "Phoenix immutable release provenance",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "repository",
    "workflow",
    "release_sha",
    "release_intent",
    "build_run_id",
    "quarantine",
    "required_jobs",
    "required_release_artifacts",
    "image_fragments",
    "release_assets",
    "release_manifest_sha256"
  ],
  "properties": {
    "schema": {
      "enum": [
        "phoenix.release-provenance.v1",
        "phoenix.release-provenance.v2",
        "phoenix.release-provenance.v3",
        "phoenix.release-provenance.v4"
      ]
    },
    "repository": {
      "const": "MajidAsghariTabrizi/anti-gravity-phoenix-v4"
    },
    "workflow": {
      "const": "Build Phoenix Images"
    },
    "release_sha": {
      "$ref": "#/$defs/sha"
    },
    "release_intent": {
      "const": "PHOENIX_PRELIVE_SHADOW_V5"
    },
    "build_run_id": {
      "$ref": "#/$defs/runId"
    },
    "quarantine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification",
        "run_ids"
      ],
      "properties": {
        "classification": {
          "const": "NON_CANONICAL_INCOMPLETE_BUILD"
        },
        "run_ids": {
          "type": "array",
          "uniqueItems": true,
          "contains": {
            "const": "29683234024"
          },
          "items": {
            "$ref": "#/$defs/runId"
          }
        }
      }
    },
    "required_jobs": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "required_release_artifacts": {
      "type": "array",
      "minItems": 9,
      "maxItems": 10,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "image_fragments": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dashboard",
        "feed-ingestor",
        "fork-sandbox",
        "live-executor",
        "phoenix-engine",
        "recorder",
        "rpc-gateway"
      ],
      "properties": {
        "dashboard": { "$ref": "#/$defs/fragment" },
        "feed-ingestor": { "$ref": "#/$defs/fragment" },
        "fork-sandbox": { "$ref": "#/$defs/fragment" },
        "live-executor": { "$ref": "#/$defs/fragment" },
        "phoenix-engine": { "$ref": "#/$defs/fragment" },
        "recorder": { "$ref": "#/$defs/fragment" },
        "rpc-gateway": { "$ref": "#/$defs/fragment" }
      }
    },
    "release_assets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_name",
        "archive_name",
        "archive_sha256",
        "manifest_sha256",
        "checksums_sha256"
      ],
      "properties": {
        "artifact_name": {
          "type": "string"
        },
        "archive_name": {
          "type": "string"
        },
        "archive_sha256": { "$ref": "#/$defs/digest" },
        "manifest_sha256": { "$ref": "#/$defs/digest" },
        "checksums_sha256": { "$ref": "#/$defs/digest" }
      }
    },
    "release_manifest_sha256": {
      "$ref": "#/$defs/digest"
    },
    "source_ci": {
      "$ref": "#/$defs/sourceCi"
    },
    "protected_base": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_sha",
        "build_run_id",
        "release_manifest_sha256",
        "release_provenance_sha256"
      ],
      "properties": {
        "release_sha": { "$ref": "#/$defs/sha" },
        "build_run_id": { "$ref": "#/$defs/runId" },
        "release_manifest_sha256": { "$ref": "#/$defs/digest" },
        "release_provenance_sha256": { "$ref": "#/$defs/digest" }
      }
    },
    "built_images": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {
        "enum": [
          "dashboard",
          "fork-sandbox",
          "live-executor",
          "phoenix-engine",
          "rpc-gateway"
        ]
      }
    },
    "inherited_images": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {
        "enum": [
          "feed-ingestor",
          "recorder"
        ]
      }
    }
  },
  "oneOf": [
    {
      "properties": {
        "schema": {
          "const": "phoenix.release-provenance.v1"
        },
        "required_release_artifacts": {
          "minItems": 9,
          "maxItems": 9
        }
      },
      "not": {
        "anyOf": [
          { "required": ["protected_base"] },
          { "required": ["built_images"] },
          { "required": ["inherited_images"] },
          { "required": ["source_ci"] }
        ]
      }
    },
    {
      "required": [
        "protected_base",
        "built_images",
        "inherited_images"
      ],
      "properties": {
        "schema": {
          "const": "phoenix.release-provenance.v2"
        },
        "required_release_artifacts": {
          "minItems": 9,
          "maxItems": 9
        }
      },
      "not": {
        "required": ["source_ci"]
      }
    },
    {
      "required": [
        "source_ci"
      ],
      "properties": {
        "schema": {
          "const": "phoenix.release-provenance.v3"
        },
        "required_release_artifacts": {
          "minItems": 10,
          "maxItems": 10
        }
      },
      "not": {
        "anyOf": [
          { "required": ["protected_base"] },
          { "required": ["built_images"] },
          { "required": ["inherited_images"] }
        ]
      }
    },
    {
      "required": [
        "source_ci",
        "protected_base",
        "built_images",
        "inherited_images"
      ],
      "properties": {
        "schema": {
          "const": "phoenix.release-provenance.v4"
        },
        "required_release_artifacts": {
          "minItems": 10,
          "maxItems": 10
        }
      }
    }
  ],
  "$defs": {
    "sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "runId": {
      "type": "string",
      "pattern": "^[1-9][0-9]{0,19}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "ciJobName": {
      "enum": [
        "hygiene",
        "go",
        "rust-phoenix",
        "rust-rpc-gateway",
        "rust-recorder",
        "rust-replay",
        "rust-fork-sandbox",
        "solidity",
        "python-dashboard",
        "docker-validation",
        "integration-fixtures",
        "jetstream-integration"
      ]
    },
    "sourceCiJob": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status",
        "conclusion"
      ],
      "properties": {
        "name": { "$ref": "#/$defs/ciJobName" },
        "status": { "const": "completed" },
        "conclusion": { "const": "success" }
      }
    },
    "sourceCi": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "repository",
        "workflow",
        "workflow_path",
        "run_id",
        "run_attempt",
        "head_sha",
        "event",
        "head_branch",
        "status",
        "conclusion",
        "required_jobs",
        "jobs",
        "evidence_sha256"
      ],
      "properties": {
        "schema": { "const": "phoenix.source-ci.v1" },
        "repository": { "const": "MajidAsghariTabrizi/anti-gravity-phoenix-v4" },
        "workflow": { "const": "Phoenix CI" },
        "workflow_path": { "const": ".github/workflows/ci.yml" },
        "run_id": { "$ref": "#/$defs/runId" },
        "run_attempt": { "$ref": "#/$defs/runId" },
        "head_sha": { "$ref": "#/$defs/sha" },
        "event": { "const": "push" },
        "head_branch": { "const": "main" },
        "status": { "const": "completed" },
        "conclusion": { "const": "success" },
        "required_jobs": {
          "type": "array",
          "minItems": 12,
          "maxItems": 12,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/ciJobName" }
        },
        "jobs": {
          "type": "array",
          "minItems": 12,
          "maxItems": 12,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/sourceCiJob" }
        },
        "evidence_sha256": { "$ref": "#/$defs/digest" }
      }
    },
    "fragment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_name",
        "sha256"
      ],
      "properties": {
        "artifact_name": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/digest"
        }
      }
    }
  }
}
